datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model UserProfile {
  id                String            @id // Steam 64-bit ID
  displayName       String            @map("display_name")
  avatarUrl         String?           @map("avatar_url")
  level             Int
  joinDate          DateTime          @map("join_date")
  communityVisibility Int             @map("community_visibility") // From your UML {1, 3}

  // Relations
  gameInformation   GameInformation[]
  sessions          Session[]

  @@map("user_profiles")
}

model Game {
  steamAppid     Int               @id @map("steam_appid") // PK from your diagram
  name           String
  genres         Json              // Stores string[]
  mainStory      Json?             @map("main_story")
  completionist  Json?             @map("completionist")
  iconUrl        String            @map("icon_url")
  logoUrl        String            @map("logo_url")

  // Relations
  gameInstances  GameInformation[]
  playtimeChecks PlaytimeCheck[]

  @@map("games")
}

model GameInformation {
  id                 String      @id @default(uuid())
  userId             String      @map("user_id")
  steamAppid         Int         @map("steam_appid")
  recentHoursPlayed  Float       @map("recent_hours_played")
  totalHoursPlayed   Float       @map("total_hours_played")
  achievements       Json        // Stores { unlocked, total, percentage }

  // Relations
  user               UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameCatalog        Game        @relation(fields: [steamAppid], references: [steamAppid], onDelete: Cascade)
  sessions           Session[]

  @@map("game_information")
}

model Session {
  id            String          @id @default(uuid())
  userId        String          @map("user_id")
  gameId        String          @map("game_id") // Changed to String to match GameInformation.id
  startAt       DateTime        @default(now()) @map("start_at")
  endAt         DateTime?       @map("end_at")
  totalDuration Int?            @map("total_duration")

  // Relations
  user           UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameInstance   GameInformation @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playtimeChecks PlaytimeCheck[]

  @@map("sessions")
}

model PlaytimeCheck {
  id                 String    @id @default(uuid())
  sessionId          String?   @map("session_id")
  gameId             Int       @map("game_id") // Kept as Int because your diagram maps it back to Game.steam_appid
  checkedAt          DateTime  @default(now()) @map("checked_at")
  cumulativePlaytime Int       @map("cumulative_playtime")

  // Relations
  session            Session?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  gameCatalog        Game      @relation(fields: [gameId], references: [steamAppid], onDelete: Cascade)

  @@map("playtime_checks")
}